@model IEnumerable<TrainingHub.Reporting.Models.EnrollmentStatDto>

@{
    ViewData["Title"] = "Enrollment Statistics";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Enrollment Statistics Dashboard</h2>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Course Name</th>
                        <th>Category</th>
                        <th class="text-center">Capacity</th>
                        <th class="text-center">Enrolled</th>
                        <th class="text-center">Remaining Spots</th>
                        <th class="w-25">Fill Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var stat in Model)
                        {
                            var progressColor = stat.FillPercentage >= 100 ? "bg-danger" :
                            stat.FillPercentage >= 80 ? "bg-warning" : "bg-success";

                            <tr>
                                <td class="align-middle fw-bold">@stat.CourseName</td>
                                <td class="align-middle">@stat.CategoryName</td>
                                <td class="align-middle text-center">@stat.TotalCapacity</td>
                                <td class="align-middle text-center">@stat.TotalEnrolled</td>
                                <td class="align-middle text-center">
                                    <span class="badge @(stat.RemainingSpots == 0 ? "bg-danger" : "bg-primary")">
                                        @stat.RemainingSpots
                                    </span>
                                </td>
                                <td class="align-middle">
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar @progressColor"
                                             role="progressbar"
                                             style="width: @stat.FillPercentage%;"
                                             aria-valuenow="@stat.FillPercentage"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                            @stat.FillPercentage%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                No enrollment data available.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>