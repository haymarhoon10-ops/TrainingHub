@model IEnumerable<TrainingHub.Reporting.Models.EnrollmentStatDto>

@{
    ViewData["Title"] = "Enrollment Statistics";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Enrollment Statistics Dashboard</h2>
        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Course Name</th>
                            <th class="py-3">Category</th>
                            <th class="text-center py-3">Capacity</th>
                            <th class="text-center py-3">Enrolled</th>
                            <th class="text-center py-3">Remaining Spots</th>
                            <th class="w-25 pe-4 py-3">Fill Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var stat in Model)
                            {
                                var progressColor = stat.FillPercentage >= 100 ? "bg-danger" :
                                stat.FillPercentage >= 80 ? "bg-warning" : "bg-success";

                                <tr>
                                    <td class="ps-4 fw-bold">@stat.CourseName</td>
                                    <td class="text-muted">@stat.CategoryName</td>
                                    <td class="text-center">@stat.TotalCapacity</td>
                                    <td class="text-center fw-semibold">@stat.TotalEnrolled</td>
                                    <td class="text-center">
                                        <span class="badge @(stat.RemainingSpots == 0 ? "bg-danger" : "bg-primary rounded-pill px-3")">
                                            @stat.RemainingSpots
                                        </span>
                                    </td>
                                    <td class="pe-4 py-3">
                                        <div class="progress shadow-sm" style="height: 25px; border-radius: 0.5rem;">
                                            <div class="progress-bar @progressColor fw-bold fs-6"
                                                 role="progressbar"
                                                 style="width: @stat.FillPercentage%;"
                                                 aria-valuenow="@stat.FillPercentage"
                                                 aria-valuemin="0"
                                                 aria-valuemax="100">
                                                @stat.FillPercentage.ToString("0")%
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    No enrollment data available for this period.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>