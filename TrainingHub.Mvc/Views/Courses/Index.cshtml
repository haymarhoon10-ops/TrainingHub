@model IEnumerable<TrainingHub.Models.Course>

@using TrainingHub.Security
@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

@if (User.IsInRole(RoleNames.TrainingCoordinator))
{
    <p>
        <a asp-action="Create">Create New</a>
    </p>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DurationHours)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DefaultCapacity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Fee)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsActive)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Category)
            </th>
            <th>
                Prerequisite
            </th>
            <th>
                Equipment
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Title)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DurationHours)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DefaultCapacity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Fee)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Category.Description)
            </td>
            <td>
                @(item.PrerequisiteCourse?.Title ?? "None")
            </td>
            <td>
                @{
                    var equipment = new List<string>();
                    if (item.RequiresProjector) equipment.Add("Projector");
                    if (item.RequiresLabComputer) equipment.Add("Lab Computer");
                }
                @(equipment.Count > 0 ? string.Join(", ", equipment) : "None")
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                @if (User.IsInRole(RoleNames.TrainingCoordinator))
                {
                    <span> | </span>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <span> | </span>
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
