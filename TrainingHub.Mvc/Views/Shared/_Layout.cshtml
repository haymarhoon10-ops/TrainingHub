@using Microsoft.EntityFrameworkCore
@inject SignInManager<ApplicationUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrainingHub.Mvc</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TrainingHub.Mvc.styles.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">

            <div class="container-fluid">

                <a class="navbar-brand"
                   asp-area=""
                   asp-controller="Home"
                   asp-action="Index">
                    TrainingHub.Mvc
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Courses" asp-action="Index">Courses</a>
                            </li>

                            @if (User.IsInRole(RoleNames.TrainingCoordinator))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="CourseSessions" asp-action="Index">Sessions</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Courses" asp-action="Create">Create Course</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="UserRoles" asp-action="Index">Manage Users</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Payments" asp-action="Index">Financials</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Enrollments" asp-action="Index">Enrollments</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="CertificationTracks" asp-action="Index">Certifications</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Certificates" asp-action="Index">Certificates</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Notifications" asp-action="Index">Notifications</a>
                                </li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Admin</a>
                                    <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                        <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Categories</a></li>
                                        <li><a class="dropdown-item" asp-controller="Classrooms" asp-action="Index">Classrooms</a></li>
                                        <li><a class="dropdown-item" asp-controller="Instructors" asp-action="Index">Instructors</a></li>
                                        <li><a class="dropdown-item" asp-controller="Trainees" asp-action="Index">Trainees</a></li>
                                        <li><a class="dropdown-item" asp-controller="UserRoles" asp-action="Index">User Roles</a></li>
                                    </ul>
                                </li>
                            }
                            else if (User.IsInRole(RoleNames.Instructor))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="CourseSessions" asp-action="Index">Sessions</a>
                                </li>
                            }
                            else if (User.IsInRole(RoleNames.Trainee))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Enrollments" asp-action="Index">Enrollments</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Certificates" asp-action="Index">Certificates</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Payments" asp-action="Index">Payments</a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Certificates" asp-action="Lookup">Public Lookup</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">@User.Identity?.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-dark">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a></li>
                            <li class="nav-item"><a class="nav-link text-dark" asp-controller="Account" asp-action="Register">Register</a></li>
                        }
                    </ul>

                </div>

            </div>

        </nav>
    </header>

    <div class="container">

        <main role="main" class="pb-3">
            @RenderBody()
        </main>

    </div>

    <footer class="border-top footer text-muted">

        <div class="container">
                &copy; 2026 - TrainingHub.Mvc -
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>