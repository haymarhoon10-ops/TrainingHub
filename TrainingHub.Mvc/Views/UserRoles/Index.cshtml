@model IEnumerable<(TrainingHub.Models.ApplicationUser User, string Role)>

@{
    ViewData["Title"] = "User Roles";
}

<h1>User Roles</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.User.FullName</td>
                <td>@item.User.Email</td>
                <td>@item.Role</td>
                <td><a asp-action="Edit" asp-route-id="@item.User.Id">Edit</a></td>
            </tr>
        }
    </tbody>
</table>