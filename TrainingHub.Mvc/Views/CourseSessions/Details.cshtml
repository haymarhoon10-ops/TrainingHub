@model TrainingHub.Models.CourseSession

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

@if (TempData["EnrollmentSuccess"] != null)
{
    <div class="alert alert-success">@TempData["EnrollmentSuccess"]</div>
}

@if (TempData["EnrollmentError"] != null)
{
    <div class="alert alert-danger">@TempData["EnrollmentError"]</div>
}

@{
    var enrolledCount = Model.Enrollments?.Count(enrollment => EnrollmentCapacityRules.CountsTowardCapacity(enrollment.Status)) ?? 0;
    var remainingSpots = Model.Capacity - enrolledCount;
    if (remainingSpots < 0)
    {
        remainingSpots = 0;
    }
}

@{
    var isTrainee = User.IsInRole(RoleNames.Trainee) && !User.IsInRole(RoleNames.TrainingCoordinator);
    var alreadyEnrolled = isTrainee && Model.Enrollments?.Any(enrollment =>
        string.Equals(enrollment.Trainee?.Email, User.Identity?.Name, StringComparison.OrdinalIgnoreCase) &&
        EnrollmentCapacityRules.CountsTowardCapacity(enrollment.Status)) == true;
}

<div>
    <h4>CourseSession</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StartDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StartDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.EndDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.EndDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Capacity)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Capacity)
        </dd>
        <dt class = "col-sm-2">
            Current Enrollments
        </dt>
        <dd class = "col-sm-10">
            <span data-live-enrollment-current data-live-enrollment-session-id="@Model.Id">@enrolledCount</span>
        </dd>
        <dt class = "col-sm-2">
            Remaining Spots
        </dt>
        <dd class = "col-sm-10">
            <span data-live-enrollment-remaining data-live-enrollment-session-id="@Model.Id">@remainingSpots</span>
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.CreatedAt)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.CreatedAt)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Course)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Course.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Instructor)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Instructor.Bio)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Classroom)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Classroom.Location)
        </dd>
    </dl>
</div>
<div>
    @if (isTrainee)
    {
        if (alreadyEnrolled)
        {
            <div class="alert alert-info">You are already enrolled in this session.</div>
        }
        else
        {
            <form asp-controller="Enrollments" asp-action="EnrollInSession" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="courseSessionId" value="@Model.Id" />
                <button type="submit" class="btn btn-primary">Enroll in This Session</button>
            </form>
            <span> | </span>
        }
    }
    @if (User.IsInRole(RoleNames.TrainingCoordinator))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
        <span> | </span>
    }
    <a asp-action="Index">Back to List</a>
</div>
