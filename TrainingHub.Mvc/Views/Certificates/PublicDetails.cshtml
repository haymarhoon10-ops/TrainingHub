@model TrainingHub.Models.Certificate

@{
    ViewData["Title"] = "Public Certificate Details";
}

<h1>Certificate Details</h1>

<div class="alert alert-info">
    This is a public certificate record. Only non-sensitive certificate data is shown.
</div>

<div>
    <h4>Certificate</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Reference</dt>
        <dd class="col-sm-10">@Model.CertificateReferenceNumber</dd>
        <dt class="col-sm-2">Issued At</dt>
        <dd class="col-sm-10">@Model.IssuedAt</dd>
        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.Status</dd>
        <dt class="col-sm-2">Trainee</dt>
        <dd class="col-sm-10">@(Model.Trainee?.FullName ?? "Unknown trainee")</dd>
        <dt class="col-sm-2">Certification Track</dt>
        <dd class="col-sm-10">@(Model.CertificationTrack?.Name ?? "Unknown track")</dd>
    </dl>
</div>

<div>
    <a asp-action="Lookup">Lookup another certificate</a>
</div>
