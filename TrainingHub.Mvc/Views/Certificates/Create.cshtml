@model TrainingHub.Models.Certificate

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Certificate</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TraineeId" class="control-label"></label>
                <select asp-for="TraineeId" class ="form-control" asp-items="ViewBag.TraineeId"></select>
            </div>
            <div class="form-group">
                <label asp-for="CertificationTrackId" class="control-label"></label>
                <select asp-for="CertificationTrackId" class ="form-control" asp-items="ViewBag.CertificationTrackId"></select>
            </div>
            <div class="form-group">
                <p class="text-muted">Reference number, issue date and status will be set automatically when a certificate is issued.</p>
            </div>
            @if(ViewBag.PassedCourses != null) {
                <div class="mb-2">
                    <strong>Passed:</strong> @ViewBag.PassedCourses / @ViewBag.TotalRequired
                    <br />
                    <strong>Remaining:</strong> @ViewBag.RemainingCourses
                    <br />
                    @if((bool)ViewBag.IsEligible) { <span class="badge bg-success">Eligible</span> } else { <span class="badge bg-secondary">Not eligible</span> }
                </div>
            }
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
