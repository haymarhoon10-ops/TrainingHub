@model IEnumerable<TrainingHub.Models.Certificate>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Reference</th>
            <th>Issued At</th>
            <th>Status</th>
            <th>Trainee</th>
            <th>Certification Track</th>
            <th>Passed / Required</th>
            <th>Remaining</th>
            <th>Eligibility</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.CertificateReferenceNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IssuedAt)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Trainee.FullName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CertificationTrack.Name)
            </td>
            <td>
                @((ViewBag.PassCounts != null && ViewBag.PassCounts[item.Id] != null) ? ViewBag.PassCounts[item.Id].ToString() : "0")
                /
                @((ViewBag.TotalRequired != null && ViewBag.TotalRequired[item.Id] != null) ? ViewBag.TotalRequired[item.Id].ToString() : "0")
            </td>
            <td>
                @((ViewBag.Remaining != null && ViewBag.Remaining[item.Id] != null) ? ViewBag.Remaining[item.Id].ToString() : "0")
            </td>
            <td>
                @{ var eligible = (ViewBag.IsEligible != null && ViewBag.IsEligible[item.Id] != null) ? (bool)ViewBag.IsEligible[item.Id] : false; }
                @if (eligible)
                {
                    <span class="badge bg-success">Eligible</span>
                }
                else
                {
                    <span class="badge bg-secondary">Not eligible</span>
                }
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
