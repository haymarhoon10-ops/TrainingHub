@model TrainingHub.Models.Enrollment

@{
    ViewData["Title"] = "Edit";
    var isAssessmentOnly = ViewBag.IsAssessmentOnly != null && (bool)ViewBag.IsAssessmentOnly;
}

<h1>@(isAssessmentOnly ? "Record Assessment" : "Edit")</h1>

<h4>Enrollment</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="TraineeId" class="control-label"></label>
                <select asp-for="TraineeId" class="form-control" asp-items="ViewBag.TraineeId" disabled="@isAssessmentOnly"></select>
                <span asp-validation-for="TraineeId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CourseSessionId" class="control-label"></label>
                <select asp-for="CourseSessionId" class="form-control" asp-items="ViewBag.CourseSessionId" disabled="@isAssessmentOnly"></select>
                <span asp-validation-for="CourseSessionId" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control" disabled="@isAssessmentOnly">
                    <option value="">-- Select status --</option>
                    <option value="Enrolled">Enrolled</option>
                    <option value="Confirmed">Confirmed</option>
                    <option value="Attending">Attending</option>
                    <option value="Completed">Completed</option>
                    <option value="Dropped">Dropped</option>
                </select>
                <small class="form-text text-muted">Choose the current enrollment lifecycle status.</small>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EnrolledAt" class="control-label"></label>
                <input asp-for="EnrolledAt" class="form-control" readonly="@isAssessmentOnly" />
                <span asp-validation-for="EnrolledAt" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="AttendanceStatus" class="control-label"></label>
                <select asp-for="AttendanceStatus" class="form-control">
                    <option value="">-- Select attendance --</option>
                    <option value="Pending">Pending</option>
                    <option value="Present">Present</option>
                    <option value="Absent">Absent</option>
                </select>
                <small class="form-text text-muted">Attendance status is used for session tracking.</small>
                <span asp-validation-for="AttendanceStatus" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ResultStatus" class="control-label"></label>
                <select asp-for="ResultStatus" class="form-control">
                    <option value="">-- Select result --</option>
                    <option value="Pending">Pending</option>
                    <option value="Pass">Pass</option>
                    <option value="Fail">Fail</option>
                </select>
                <small class="form-text text-muted">Record the final result for this enrollment.</small>
                <span asp-validation-for="ResultStatus" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ResultRecordedAt" class="control-label"></label>
                <input asp-for="ResultRecordedAt" class="form-control" />
                <span asp-validation-for="ResultRecordedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="@(isAssessmentOnly ? "Record Result" : "Save")" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
