@model TrainingHub.Models.CertificationTrack

@{
    ViewData["Title"] = "Certification Progress";
}

<h1>Certification Progress</h1>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">
        @ViewBag.ErrorMessage
    </div>
}
else
{
    <div class="card p-4">
        <h3>@Model.Name</h3>

        <p>
            <strong>Trainee:</strong> @ViewBag.TraineeName
        </p>

        <p>
            <strong>Completed Courses:</strong> @ViewBag.CompletedCount
        </p>

        <p>
            <strong>Total Required Courses:</strong> @ViewBag.TotalRequired
        </p>

        <p>
            <strong>Progress:</strong> @ViewBag.ProgressPercentage%
        </p>

        <div class="progress mb-3">
            <div class="progress-bar"
                 role="progressbar"
                 style="width: @ViewBag.ProgressPercentage%;">
                @ViewBag.ProgressPercentage%
            </div>
        </div>

        <h4>Required Courses</h4>

        <ul>
            @foreach (var item in Model.CertificationTrackCourses)
            {
                <li>@item.Course?.Title</li>
            }
        </ul>
    </div>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>